{
  "info": {
    "name": "E-Commerce Order System - Phase 2",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Ready-to-run Postman collection for the E-Commerce Order System modular monolith."
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "customerId",
      "value": "11111111-1111-1111-1111-111111111111"
    },
    {
      "key": "productId1",
      "value": "33333333-3333-3333-3333-333333333333"
    },
    {
      "key": "productId2",
      "value": "44444444-4444-4444-4444-444444444444"
    },
    {
      "key": "conflictProductId",
      "value": "55555555-5555-5555-5555-555555555555"
    },
    {
      "key": "orderId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "List Customers",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status is 200\", function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test(\"Customers returned\", function () {",
              "  const data = pm.response.json();",
              "  pm.expect(Array.isArray(data)).to.eql(true);",
              "  pm.expect(data.length).to.be.greaterThan(0);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/api/customers"
      }
    },
    {
      "name": "List Products",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status is 200\", function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test(\"Products returned\", function () {",
              "  const data = pm.response.json();",
              "  pm.expect(Array.isArray(data)).to.eql(true);",
              "  pm.expect(data.length).to.be.greaterThan(0);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/api/products"
      }
    },
    {
      "name": "List Inventory Items",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status is 200\", function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test(\"Inventory returned\", function () {",
              "  const data = pm.response.json();",
              "  pm.expect(Array.isArray(data)).to.eql(true);",
              "  pm.expect(data.length).to.be.greaterThan(0);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/api/inventory-items"
      }
    },
    {
      "name": "List Orders",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status is 200\", function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test(\"HATEOAS links returned\", function () {",
              "  const data = pm.response.json();",
              "  pm.expect(data._links).to.exist;",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/api/orders"
      }
    },
    {
      "name": "Create Order",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status is 201\", function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "const data = pm.response.json();",
              "pm.collectionVariables.set(\"orderId\", data.id);",
              "pm.test(\"Order has links\", function () {",
              "  pm.expect(data._links).to.exist;",
              "  pm.expect(data._links.self).to.exist;",
              "  pm.expect(data._links.collection).to.exist;",
              "});",
              "pm.test(\"Order has aggregated data\", function () {",
              "  pm.expect(data.customer).to.exist;",
              "  pm.expect(data.items.length).to.be.greaterThan(0);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"customerId\": \"{{customerId}}\",\n  \"items\": [\n    {\n      \"productId\": \"{{productId1}}\",\n      \"quantity\": 1\n    },\n    {\n      \"productId\": \"{{productId2}}\",\n      \"quantity\": 2\n    }\n  ]\n}"
        },
        "url": "{{baseUrl}}/api/orders"
      }
    },
    {
      "name": "Get Created Order By Id",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "if (!pm.collectionVariables.get(\"orderId\")) {",
              "  throw new Error(\"Run 'Create Order' first\");",
              "}"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status is 200\", function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const data = pm.response.json();",
              "pm.test(\"Fetched order matches orderId\", function () {",
              "  pm.expect(data.id).to.eql(pm.collectionVariables.get(\"orderId\"));",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/api/orders/{{orderId}}"
      }
    },
    {
      "name": "Update Order Status",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "if (!pm.collectionVariables.get(\"orderId\")) {",
              "  throw new Error(\"Run 'Create Order' first\");",
              "}"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status is 200\", function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const data = pm.response.json();",
              "pm.test(\"Status changed to SHIPPED\", function () {",
              "  pm.expect(data.status).to.eql(\"SHIPPED\");",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"status\": \"SHIPPED\"\n}"
        },
        "url": "{{baseUrl}}/api/orders/{{orderId}}"
      }
    },
    {
      "name": "Create Product - Validation Error (400)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status is 400\", function () {",
              "  pm.response.to.have.status(400);",
              "});",
              "const data = pm.response.json();",
              "pm.test(\"Validation failed\", function () {",
              "  pm.expect(data.message).to.eql(\"Validation failed\");",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Bad Product\",\n  \"price\": 0\n}"
        },
        "url": "{{baseUrl}}/api/products"
      }
    },
    {
      "name": "Create Order - Conflict Error (409)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status is 409\", function () {",
              "  pm.response.to.have.status(409);",
              "});",
              "const data = pm.response.json();",
              "pm.test(\"Conflict returned\", function () {",
              "  pm.expect(data.error).to.eql(\"Conflict\");",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"customerId\": \"{{customerId}}\",\n  \"items\": [\n    {\n      \"productId\": \"{{conflictProductId}}\",\n      \"quantity\": 100\n    }\n  ]\n}"
        },
        "url": "{{baseUrl}}/api/orders"
      }
    }
  ]
}
