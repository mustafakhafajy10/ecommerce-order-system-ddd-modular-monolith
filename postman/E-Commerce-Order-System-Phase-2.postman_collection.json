          "name": "Create Product - Validation Error (400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status is 400\", function () {",
                  "    pm.response.to.have.status(400);",
                  "});",
                  "",
                  "pm.test(\"Validation message includes price\", function () {",
                  "    const data = pm.response.json();",
                  "    pm.expect(data.message).to.eql(\"Validation failed\");",
                  "    pm.expect(data.details.price).to.exist;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
