        {
          "name": "Create Customer",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"201 Created\", function () { pm.response.to.have.status(201); });",
                  "const data = pm.response.json();",
                  "pm.collectionVariables.set('createdCustomerId', data.id);"
                ]
