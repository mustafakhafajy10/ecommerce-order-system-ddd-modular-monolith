          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Charlie Demo {{$timestamp}}\",\n  \"email\": \"charlie.demo.{{$timestamp}}@example.com\"\n}"
